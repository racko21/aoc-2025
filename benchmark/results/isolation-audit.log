2026-06-24T15:52:50.540788+00:00 python day03 run_bash: python3 -c "
def max_joltage(bank, k):
    n = len(bank)
    if k > n:
        return 0
    result = []
    start = 0
    for i in range(k):
        end = n - (k - i - 1)
        best_val = -1
        best_pos = start
        for j in range(start, end):
            if int(bank[j]) > best_val:
                best_val = int(bank[j])
                best_pos = j
        result.append(bank[best_pos])
        start = best_pos + 1
    return int(''.join(result))

banks = ['987654321111111', '811111111111119', '234234234234278', '818181911112111']

print('=== Part 1 (k=2) ===')
for b in banks:
    v = max_joltage(b, 2)
    print(f'{b} -> {v}')
print('Total:', sum(max_joltage(b, 2) for b in banks))

print()
print('=== Part 2 (k=12) ===')
for b in banks:
    v = max_joltage(b, 12)
    print(f'{b} -> {v}')
print('Total:', sum(max_joltage(b, 12) for b in banks))
"

