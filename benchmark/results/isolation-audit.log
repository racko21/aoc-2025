# Also test with example
python3 -c "
import sys
sys.path.insert(0, '/solution')

# Inline the solution with example.txt
def parse_ranges(text):
    text = text.strip().replace('\n', '').replace(' ', '')
    ranges = []
    for part in text.split(','):
        part = part.strip()
        if not part:
            continue
        a, b = part.split('-')
        ranges.append((int(a), int(b)))
    return ranges

def is_in_ranges(n, ranges):
    for a, b in ranges:
        if a <= n <= b:
            return True
    return False

def generate_double_repeat_candidates(ranges):
    max_val = max(b for a, b in ranges)
    max_len = len(str(max_val))
    candidates = set()
    for L in range(1, max_len // 2 + 2):
        s_start = 10 ** (L - 1) if L > 1 else 1
        s_end = 10 ** L - 1
        for s in range(s_start, s_end + 1):
            s_str = str(s)
            ss_str = s_str + s_str
            ss = int(ss_str)
            if ss > max_val:
                break
            candidates.add(ss)
    return candidates

def generate_multi_repeat_candidates(ranges):
    max_val = max(b for a, b in ranges)
    max_digits = len(str(max_val))
    candidates = set()
    for L in range(1, max_digits + 1):
        for k in range(2, max_digits // L + 1):
            s_start = 10 ** (L - 1) if L > 1 else 1
            s_end = 10 ** L - 1
            for s in range(s_start, s_end + 1):
                s_str = str(s)
                repeated_str = s_str * k
                val = int(repeated_str)
                if val > max_val:
                    break
                candidates.add(val)
    return candidates

text = open('/solution/example.txt').read()
ranges = parse_ranges(text)
print('Ranges:', ranges)

c1 = generate_double_repeat_candidates(ranges)
c1_in_range = sorted(n for n in c1 if is_in_ranges(n, ranges))
print('Part 1 candidates in range:', c1_in_range)
print('Part 1 sum:', sum(c1_in_range))

c2 = generate_multi_repeat_candidates(ranges)
c2_in_range = sorted(n for n in c2 if is_in_ranges(n, ranges))
print('Part 2 candidates in range:', c2_in_range)
print('Part 2 sum:', sum(c2_in_range))
"

