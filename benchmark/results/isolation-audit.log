typedef unsigned long long ull;

static ull pow10_f(int e) {
    ull r = 1; for (int i=0;i<e;i++) r*=10; return r;
}

int main() {
    ull limit = 6856492968ULL; /* max from real input */
    int count1 = 0, count2 = 0;
    
    /* Part 1 count */
    for (int h = 1; h <= 10; h++) {
        ull base = pow10_f(h);
        ull x_lo = (h == 1) ? 1 : pow10_f(h-1);
        ull x_hi = pow10_f(h) - 1;
        for (ull x = x_lo; x <= x_hi; x++) {
            ull id = x * base + x;
            if (id > limit) break;
            count1++;
        }
        if (x_lo * base + x_lo > limit) break;
    }
    printf("Part 1 count (before dedup): %d\n", count1);
    
    /* Part 2 count (rough) */
    for (int d = 1; d <= 10; d++) {
        ull x_lo = (d == 1) ? 1 : pow10_f(d-1);
        ull x_hi = pow10_f(d) - 1;
        ull base_d = pow10_f(d);
        for (int r = 2; r <= 20; r++) {
            int total_len = d * r;
            if (total_len > 20) break;
            ull mult = 0, pw = 1;
            int overflow = 0;
            for (int i = 0; i < r; i++) {
                ull nm = mult + pw; if (nm < mult) { overflow=1; break; }
                mult = nm;
                ull np = pw * base_d; if (np < pw && i < r-1) { overflow=1; break; }
                pw = np;
            }
            if (overflow) break;
            __uint128_t lo128 = (__uint128_t)x_lo * mult;
            if (lo128 > (__uint128_t)limit) break;
            for (ull x = x_lo; x <= x_hi; x++) {
                __uint128_t id128 = (__uint128_t)x * mult;
                if (id128 > (__uint128_t)limit) break;
                count2++;
            }
        }
    }
    printf("Part 2 count (before dedup): %d\n", count2);
    return 0;
}
