import time, random
from collections import Counter

def normalize_shape(cells):
    if not cells: return frozenset()
    min_r = min(r for r, c in cells)
    min_c = min(c for r, c in cells)
    return frozenset((r - min_r, c - min_c) for r, c in cells)

def get_orientations(shape):
    cells = list(shape)
    orientations = set()
    current = cells
    for _ in range(4):
        norm = normalize_shape(current)
        orientations.add(norm)
        flipped = normalize_shape([(r, -c) for r, c in norm])
        orientations.add(flipped)
        current = [(c, -r) for r, c in current]
    return list(orientations)

def get_all_placements(shape_cells, width, height):
    orientations = get_orientations(shape_cells)
    placements = set()
    for orient in orientations:
        cells = list(orient)
        max_r = max(r for r, c in cells)
        max_c = max(c for r, c in cells)
        for dr in range(height - max_r):
            for dc in range(width - max_c):
                placed = frozenset((r + dr, c + dc) for r, c in cells)
                placements.add(placed)
    return list(placements)

def parse_shape(lines_list):
    cells = set()
    for r, line in enumerate(lines_list):
        for c, ch in enumerate(line):
            if ch == '#': cells.add((r, c))
    return frozenset(cells)

with open('input.txt') as f:
    content = f.read()
lines = content.strip().split('\n')
shapes = []
current_shape_lines = []
current_idx = None
for line in lines:
    stripped = line.strip()
    if stripped.endswith(':') and stripped[:-1].isdigit():
        if current_idx is not None and current_shape_lines:
            shapes.append(parse_shape(current_shape_lines))
        current_idx = int(stripped[:-1])
        current_shape_lines = []
    elif 'x' in stripped and ':' in stripped and not set(stripped.split(':')[0]) <= {'#','.', ' '}:
        if current_idx is not None and current_shape_lines:
            shapes.append(parse_shape(current_shape_lines))
            current_idx = None
        break
    elif current_idx is not None and stripped and all(c in '#.' for c in stripped):
        current_shape_lines.append(stripped)

shape_cells_counts = [len(s) for s in shapes]

regions = []
for line in lines:
    stripped = line.strip()
    if 'x' in stripped and ':' in stripped and not set(stripped.split(':')[0]) <= {'#','.', ' '}:
        colon_idx = stripped.index(':')
        dims = stripped[:colon_idx].strip()
        counts_str = stripped[colon_idx+1:].strip()
        w, h = dims.split('x')
        regions.append((int(w), int(h), list(map(int, counts_str.split()))))

# Try a SMARTER greedy: place pieces at positions with FEWEST conflicting options
# i.e., scan the grid cell by cell, and place a piece covering the first uncovered cell
# This is more like the exact cover approach

def try_fit_smart(width, height, counts, shapes, max_restarts=100):
    # Build placements per shape type
    shape_placements = {}
    unique_idxs = [i for i, c in enumerate(counts) if c > 0]
    for idx in unique_idxs:
        shape_placements[idx] = get_all_placements(shapes[idx], width, height)
    
    # Sort placements by 'top-left corner' position
    for idx in shape_placements:
        shape_placements[idx].sort(key=lambda p: min(r*width+c for r,c in p))
    
    # Build cell -> placements index for each shape
    cell_to_pl = {}
    for idx in shape_placements:
        for p in shape_placements[idx]:
            min_cell = min(r*width+c for r,c in p)
            key = (idx, min_cell)
            if key not in cell_to_pl:
                cell_to_pl[key] = []
            cell_to_pl[key].append(p)
    
    piece_list = []
    for idx, cnt in enumerate(counts):
        piece_list.extend([idx] * cnt)
    
    total_cells = sum(shape_cells_counts[i] for i in piece_list)
    if total_cells > width * height:
        return False
    
    # Randomized backtracking with 'first uncovered cell' strategy
    # Since we're not doing full tiling, the 'first cell' approach won't work directly
    # But we can try: for each restart, shuffle piece order, use greedy placement
    
    for restart in range(max_restarts):
        occupied = set()
        random.shuffle(piece_list)
        success = True
        
        for idx in piece_list:
            # Try to place piece with smallest 'top-left' first
            placed = False
            pls = shape_placements[idx]
            if restart > 0:
                # Randomize
                pls = list(pls)
                random.shuffle(pls)
            
            for p in pls:
                if not (p & occupied):
                    occupied |= p
                    placed = True
                    break
            
            if not placed:
                success = False
                break
        
        if success:
            return True
    
    return None  # Unknown

# Test the highest density region
d_region = (42, 45, [36, 40, 45, 34, 40, 41])  # region 381
width, height, counts = d_region
t0 = time.time()
result = try_fit_smart(width, height, counts, shapes, max_restarts=1000)
print(f'Region 381 ({width}x{height}), density={sum(c*shape_cells_counts[i] for i,c in enumerate(counts))/(width*height):.3f}: {result} in {time.time()-t0:.2f}s')
" 2>&1

