#include <stdio.h>
#include <string.h>

#define MAX_CELLS 10
typedef struct { int r[MAX_CELLS], c[MAX_CELLS], n; } Shape;

void normalize(Shape *s) {
    int minr=999, minc=999;
    for(int i=0;i<s->n;i++){if(s->r[i]<minr)minr=s->r[i];if(s->c[i]<minc)minc=s->c[i];}
    for(int i=0;i<s->n;i++){s->r[i]-=minr;s->c[i]-=minc;}
    for(int i=0;i<s->n-1;i++)for(int j=i+1;j<s->n;j++){
        if(s->r[j]<s->r[i]||(s->r[j]==s->r[i]&&s->c[j]<s->c[i])){
            int t=s->r[i];s->r[i]=s->r[j];s->r[j]=t;
            t=s->c[i];s->c[i]=s->c[j];s->c[j]=t;
        }
    }
}
int same(Shape *a, Shape *b) {
    if(a->n!=b->n)return 0;
    for(int i=0;i<a->n;i++)if(a->r[i]!=b->r[i]||a->c[i]!=b->c[i])return 0;
    return 1;
}
Shape rotate90(Shape *s) {
    Shape t; t.n=s->n;
    for(int i=0;i<s->n;i++){t.r[i]=s->c[i];t.c[i]=-s->r[i];}
    normalize(&t); return t;
}
Shape flip(Shape *s) {
    Shape t; t.n=s->n;
    for(int i=0;i<s->n;i++){t.r[i]=s->r[i];t.c[i]=-s->c[i];}
    normalize(&t); return t;
}

void getOrients(Shape *base, Shape *orients, int *num) {
    *num=0;
    Shape cur = *base;
    for(int f=0;f<2;f++) {
        for(int r=0;r<4;r++) {
            int dup=0;
            for(int i=0;i<*num;i++)if(same(&cur,&orients[i])){dup=1;break;}
            if(!dup)orients[(*num)++]=cur;
            cur=rotate90(&cur);
        }
        cur=flip(&cur);
    }
}

int main() {
    // All real input shapes
    // 0: ### #.# #.#
    Shape s0 = {{0,0,0,1,1,2,2},{0,1,2,0,2,0,2},7};
    // 1: #.. ##. ###
    Shape s1 = {{0,1,1,2,2,2},{0,0,1,0,1,2},6};
    // 2: ### ### ..#
    Shape s2 = {{0,0,0,1,1,1,2},{0,1,2,0,1,2,2},7};
    // 3: .## ##. ###
    Shape s3 = {{0,0,1,1,2,2,2},{1,2,0,1,0,1,2},7};
    // 4: ### .#. ###
    Shape s4 = {{0,0,0,1,2,2,2},{0,1,2,1,0,1,2},7};
    // 5: .## ##. #..
    Shape s5 = {{0,0,1,1,2},{1,2,0,1,0},5};
    
    Shape shapes[6] = {s0,s1,s2,s3,s4,s5};
    
    for(int i=0;i<6;i++) {
        normalize(&shapes[i]);
        Shape orients[8]; int num=0;
        getOrients(&shapes[i], orients, &num);
        printf("Shape %d: %d cells, %d orientations\n", i, shapes[i].n, num);
    }
    return 0;
}
EOF
