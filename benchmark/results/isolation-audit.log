from fractions import Fraction
import itertools

def ilp_brute_force(A, b, n_vars, max_val=300):
    'Try all possible combinations up to max_val - for small n_vars only'
    best = None
    # For 2-3 vars, try brute force
    if n_vars > 4:
        return 'too many vars'
    
    ranges = [range(0, max_val+1)] * n_vars
    for combo in itertools.product(*[range(max_val+1)]*n_vars):
        # Check constraints
        ok = True
        for i, bi in enumerate(b):
            total = sum(A[i][j] * combo[j] for j in range(n_vars))
            if total != bi:
                ok = False
                break
        if ok:
            s = sum(combo)
            if best is None or s < best:
                best = s
    return best

