                best_valid = valid
                best_pos = pos
                if cnt == 0: return False
        new_remaining = remaining[:best_pos] + remaining[best_pos+1:]
        for placement in best_valid:
            if backtrack(occupied | placement, new_remaining):
                return True
        return False
    
